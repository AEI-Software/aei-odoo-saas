<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>

        <!-- ── Extend sale.subscription.template form ───────────────── -->
        <record id="view_sale_subscription_template_form_saas" model="ir.ui.view">
            <field name="name">sale.subscription.template.form.saas</field>
            <field name="model">sale.subscription.template</field>
            <field name="inherit_id" ref="subscription_oca.sale_subscription_template_form"/>
            <field name="arch" type="xml">
                <xpath expr="//sheet" position="inside">
                    <group string="SaaS Configuration">
                        <field name="is_saas_plan" widget="boolean_toggle"/>
                        <field name="plan" invisible="not is_saas_plan"/>
                        <field name="storage_gi" invisible="not is_saas_plan"/>
                        <field name="product_id" invisible="not is_saas_plan"
                               domain="[('type', 'in', ['service', 'consu'])]"
                               help="Product placed on the recurring billing line. Required for automatic billing updates on plan changes."/>
                        <field name="recurring_price" invisible="not is_saas_plan"
                               help="Monthly price for this plan. Leave 0 to use the product's list price."/>
                    </group>
                    <group string="Per-User Pricing" col="4"
                           invisible="not is_saas_plan">
                        <field name="included_users"/>
                        <field name="price_per_extra_user"/>
                    </group>
                </xpath>
            </field>
        </record>

    </data>
</odoo>
