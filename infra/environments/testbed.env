# =============================================================================
# infra/environments/testbed.env — Testbed de portabilidad en cruzoil (10.9.13.2)
#
# Simula una "nube genérica": 4 VMs KVM sobre bridge br0, sin Ceph ni RadosGW.
#   k3s-test-1..3  10.9.13.21-23  (K3s servers, Longhorn)
#   pg-test-1      10.9.13.24     (Patroni single + MinIO)
#   kube-vip       10.9.13.20
#
# Uso:
#   ./infra/k3s-ha/deploy-k3s-cluster.sh infra/environments/testbed.env
#   ./infra/postgres-ha/deploy-all.sh    infra/environments/testbed.env
#   ./infra/apply-manifests.sh --env infra/environments/testbed.env
# =============================================================================

ENV_NAME="testbed"

# ─── SSH ─────────────────────────────────────────────────────────────────────
SSH_USER="ubuntu"
SSH_KEY="/home/kali/it911/pentest_it911/hardening/keys/it911_admin_ed25519"

# ─── Nodos K3s: "name:ssh_ip:internal_ip" (single-NIC: ambas IPs iguales) ────
K3S_NODES=(
  "k3s-test-1:10.9.13.21:10.9.13.21"
  "k3s-test-2:10.9.13.22:10.9.13.22"
  "k3s-test-3:10.9.13.23:10.9.13.23"
)
K3S_WORKER_NODES=()             # sin workers dedicados — los 3 servers agendan pods
KUBE_VIP_IP="10.9.13.20"
K3S_INTERFACE="enp1s0"          # verificar en la primera VM: ip -br link

# ─── Storage ─────────────────────────────────────────────────────────────────
STORAGE_BACKEND="longhorn"
STORAGE_CLASS="longhorn"
CEPH_MON_HOSTS=""

# ─── PostgreSQL ──────────────────────────────────────────────────────────────
PG_TOPOLOGY="single"
PG_NODES=(
  "pg-test-1:10.9.13.24:10.9.13.24"
)
PG_ENDPOINT_IPS="10.9.13.24"
PG_CHECK_IPS="10.9.13.24"
PG_NETWORK_CIDR="10.9.13.0/24"   # egress de tenants hacia HAProxy (NetworkPolicy del portal)

# ─── Backups S3 (MinIO en pg-test-1, TLS self-signed) ────────────────────────
S3_USE_STUNNEL="false"
S3_REPO_ENDPOINT="10.9.13.24:9000"             # pgBackRest directo a MinIO (verify-tls=n)
BACKUP_S3_ENDPOINT="https://10.9.13.24:9000"   # cronjobs del clúster

# ─── Dominio / ingress ───────────────────────────────────────────────────────
# Ruta *.test.aeisoftware.com en el tunnel cloudflared existente del host cruzoil
# (contenedor 6ad434184e13) apuntando a http://10.9.13.20 — NO se despliega
# cloudflared dentro del clúster (07-cloudflare-tunnel.yaml excluido abajo).
BASE_DOMAIN="test.aeisoftware.com"
WILDCARD_HOSTNAME="*.test.aeisoftware.com"

# ─── Manifiestos a excluir en apply-manifests.sh ─────────────────────────────
# Sin stack odoo-admin de producción ni cloudflared in-cluster.
# 05c requiere CRD ServiceMonitor (kube-prometheus, no instalado en testbed)
MANIFEST_EXCLUDE="05c-portal-servicemonitor.yaml 06-odoo-admin.yaml 06b-odoo-admin-netpol.yaml 07-cloudflare-tunnel.yaml"
