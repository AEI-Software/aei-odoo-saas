# =============================================================================
# infra/environments/cotas.env — Entorno COTAS (Platform9 OpenStack, cloud.cotas.com)
#
# Inventario y configuración NO-secreta del entorno. Los secretos siguen en:
#   .secrets.env (raíz), infra/k3s-ha/.env, infra/postgres-ha/.env|.secrets.generated
#
# Uso: los orquestadores aceptan la ruta de este archivo como primer argumento.
# Sin argumento, cargan este archivo (cotas es el default = comportamiento actual).
#   ./infra/k3s-ha/deploy-k3s-cluster.sh [infra/environments/cotas.env]
#   ./infra/postgres-ha/deploy-all.sh    [infra/environments/cotas.env]
#   ./infra/apply-manifests.sh           [--env infra/environments/cotas.env]
#
# Nota: se "sourcea" con bash — se permiten arrays y $REPO_ROOT/$SCRIPT_DIR
# (definidos por el orquestador antes del source).
# =============================================================================

ENV_NAME="cotas"

# ─── SSH ─────────────────────────────────────────────────────────────────────
SSH_USER="ubuntu"
SSH_KEY="${SSH_KEY:-$HOME/.ssh/id_rsa}"   # clave con acceso a los nodos

# ─── Nodos K3s: "name:ssh_ip:internal_ip" ────────────────────────────────────
K3S_NODES=(
  "k3s-1:10.40.2.158:192.168.0.185"   # k3s-control-1 / blade02
  "k3s-2:10.40.2.153:192.168.0.211"   # k3s-control-2 / blade01
  "k3s-3:10.40.2.159:192.168.0.243"   # k3s-control-3 / blade03
)
K3S_WORKER_NODES=(
  "k3s-worker-1:10.40.2.200:192.168.0.148"
  "k3s-worker-2:10.40.2.190:192.168.0.61"
  "k3s-worker-3:10.40.2.171:192.168.0.190"
)
KUBE_VIP_IP="192.168.0.150"
K3S_INTERFACE="ens3"

# ─── Storage ─────────────────────────────────────────────────────────────────
STORAGE_BACKEND="ceph"          # ceph | longhorn
STORAGE_CLASS="ceph-rbd"
# Ceph (no-secreto; las keys CEPH_CSI_KEY/CEPH_ADMIN_KEY van en infra/k3s-ha/.env)
CEPH_CLUSTER_ID="99efe072-cf04-11f0-adef-0cc47af94ce2"
CEPH_MON_1="10.40.1.240:6789"
CEPH_MON_2="10.40.1.241:6789"
CEPH_RBD_POOL="k3s-rbd"
CEPH_MON_HOSTS="10.40.1.240 10.40.1.241"   # para check de conectividad en prepare-node

# ─── PostgreSQL HA ───────────────────────────────────────────────────────────
PG_TOPOLOGY="ha"                # ha (3 nodos) | single (1 nodo)
PG_NODES=(
  "pg-node1:10.40.2.182:192.168.0.127"
  "pg-node2:10.40.2.174:192.168.0.186"
  "pg-node3:10.40.2.193:192.168.0.226"
)
# IPs que el Service "postgres" del clúster usa como Endpoints (puertos 5000/5001/5002)
PG_ENDPOINT_IPS="192.168.0.127 192.168.0.186 192.168.0.226"
PG_CHECK_IPS="192.168.0.127 192.168.0.186 192.168.0.226"   # check warn-only en prepare-node
PG_NETWORK_CIDR="192.168.0.0/24"   # egress de tenants hacia HAProxy (NetworkPolicy del portal)

# ─── Backups S3 (pgBackRest en nodos PG + cronjobs del clúster) ──────────────
S3_USE_STUNNEL="true"                          # RadosGW no tiene TLS → proxy stunnel local
S3_REPO_ENDPOINT="127.0.0.1:18480"             # endpoint que usa pgBackRest (stunnel local)
BACKUP_S3_ENDPOINT="http://10.40.1.240:7480"   # endpoint que usan los cronjobs del clúster

# ─── Dominio / ingress ───────────────────────────────────────────────────────
BASE_DOMAIN="aeisoftware.com"
WILDCARD_HOSTNAME="*.aeisoftware.com"

# ─── Manifiestos a excluir en apply-manifests.sh (separados por espacio) ─────
MANIFEST_EXCLUDE=""
