<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <!-- Legacy: provision status polling (provisioningâ†’ready via individual GET) -->
  <record id="ir_cron_check_instance_status" model="ir.cron">
    <field name="name">SaaS: Refresh Instance Status (legacy)</field>
    <field name="model_id" ref="odoo_k8s_saas.model_saas_instance"/>
    <field name="state">code</field>
    <field name="code">
model.search([('state', '=', 'provisioning')]).action_check_status()
    </field>
    <field name="interval_number">2</field>
    <field name="interval_type">minutes</field>
    <field name="active">False</field>
  </record>

  <!-- Full K8s reconciliation: detects drift, orphans, and missing namespaces -->
  <record id="ir_cron_reconcile_all" model="ir.cron">
    <field name="name">SaaS: Reconcile All Instances with K8s</field>
    <field name="model_id" ref="odoo_k8s_saas.model_saas_instance"/>
    <field name="state">code</field>
    <field name="code">model._cron_reconcile_all()</field>
    <field name="interval_number">2</field>
    <field name="interval_type">minutes</field>
    <field name="active">True</field>
  </record>
</odoo>
