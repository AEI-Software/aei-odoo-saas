<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>

        <!-- ── Tarjeta "Soporte técnico" en /my/subscriptions/<id> ────── -->
        <template id="portal_subscription_support_card"
                  inherit_id="odoo_k8s_saas_subscription.portal_subscription_page"
                  name="Portal: Support Hours Card">
            <xpath expr="//div[@id='saas_instance_details']" position="after">
                <div id="saas_support_hours" class="card mb-4">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <span><i class="fa fa-life-ring me-2"/>Soporte técnico — mes en curso</span>
                        <a href="/my/tickets" class="btn btn-sm btn-primary">
                            <i class="fa fa-plus me-1"/>Mis tickets
                        </a>
                    </div>
                    <div class="card-body">
                        <div class="row text-center g-3">
                            <div class="col-4">
                                <div class="text-muted small">Horas incluidas</div>
                                <div class="h4 mb-0">
                                    <t t-esc="'%.1f' % subscription.support_hours_total"/>h
                                </div>
                            </div>
                            <div class="col-4">
                                <div class="text-muted small">Consumidas</div>
                                <div class="h4 mb-0">
                                    <t t-esc="'%.1f' % subscription.support_hours_consumed"/>h
                                </div>
                            </div>
                            <div class="col-4">
                                <div class="text-muted small">Disponibles</div>
                                <div t-attf-class="h4 mb-0 #{'text-danger' if subscription.support_hours_available &lt; 0 else 'text-success'}">
                                    <t t-esc="'%.1f' % subscription.support_hours_available"/>h
                                </div>
                            </div>
                        </div>
                        <div class="text-muted small mt-3 mb-0">
                            Las horas incluidas se renuevan cada mes y no son acumulables.
                            ¿Necesitas más horas? Contáctanos para agregar un paquete de soporte adicional.
                        </div>
                    </div>
                </div>
            </xpath>
        </template>

    </data>
</odoo>
